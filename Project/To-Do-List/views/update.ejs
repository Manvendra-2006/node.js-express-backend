<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Task</title>
        <link href="style.css" rel="stylesheet"/>
</head>
<body>
    <%- include('navbar')%>
    <h1>Update Task</h1>
        <form action="/update/<%= data._id%>" method="post">
        <input type="text" placeholder="Enter Task" name="tasktittle" value="<%= data.tasktittle%>">
        <br>
        <br>
        <input type="description" placeholder="Enter Task description" name="description" value="<%= data.description%>">
        <br>
        <br>
        <button type="submit">Update Task</button>
    </form>
</body>

</html>