<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Home Page</h1>
    <%if(Data) {%>
    <%Data.map((item)=>{%>
       <table >
        <thead >
            <th>Name</th>
            <th>Class</th>
            <th>Subject</th>
        </thead>
        <tbody>
            <td> <%= item.name%></td>
            <td><%= item.classes%></td>
            <td> <%= item.subject%></td>     
            <td><%= item._id%></td>
                <td><button><a href="/edit-student/<%= item._id%>">Edit</a></button></td>
                <td><a href="/delete-student/<%= item._id%>">Delete</a></td>
        </tbody>
       </table>       
        <%})%>
        <%}%>
</body>
</html>